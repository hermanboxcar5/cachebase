                const response =3D await fetch('/!/forms/contact', {
                    method: 'POST',
                    headers: { 'Accept': 'application/json' },
                    body: formData
                });
                const data =3D await response.json();
                if (response.ok) {
                    this.contactSuccess =3D true;
                    event.target.reset();
                } else {
                    this.contactErrors =3D data.errors || {};
                }
